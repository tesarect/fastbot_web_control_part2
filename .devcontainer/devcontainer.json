{
  "name": "Fastbot Webapp",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },

  "forwardPorts": [7000, 9090, 11315],
  "portsAttributes": {
    "7000": {
      "label": "Vite dev server",
      "onAutoForward": "openBrowser"
    },
    "9090": {
      "label": "rosbridge (websocket)",
      "onAutoForward": "silent"
    },
    "11315": {
      "label": "web_video_server",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "ms-python.python"
      ]
    }
  },

  "postCreateCommand": "corepack enable && corepack prepare pnpm@latest --activate && cd fastbot_webapp && pnpm install",

  "remoteUser": "vscode"
}
